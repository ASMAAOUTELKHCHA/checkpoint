import math
class Calculatrice:
    def __init__(calc):
        calc.operations = {
            '+': lambda x, y: x + y,
            '-': lambda x, y: x - y,
            '*': lambda x, y: x * y,
            '/': lambda x, y: x / y if y != 0 else "Erreur"
        }


    def add_operation(calc, symbole, fonction):
        calc.operations[symbole] = fonction

    def calcule(calcul, a, symbole, b=0):
        if symbole not in calcul.operations:
            return "invalid"
        return calcul.operations[symbole](a, b)

# Opérations avancées
def exponentiation(x, y):
    return x ** y

def racine_carre(x, _):
    return math.sqrt(x) if x >= 0 else "Erreur : racine négative"

def logarithme(x, _):
    return math.log(x) if x > 0 else "Erreur : logarithme ≤ 0"

# Programme principal
def main():
    calc = Calculatrice()
    calc.add_operation('^', exponentiation)
    calc.add_operation('√', racine_carre)
    calc.add_operation('log', logarithme)

    print("Bienvenue dans la calculatrice avancée !")
    print("Opérations disponibles :", ', '.join(calc.operations.keys()))

    while True:
        user_input = input("Entrez votre calcul (ex: 5 + 3) ou 'q' pour quitter : ")
        if user_input.lower() == 'q':
            print("Au revoir !")
            break

        try:
            parts = user_input.split()
            if len(parts) == 2:  
                symbole, a = parts
                a = float(a)
                result = calc.calcule(a, symbole)
            elif len(parts) == 3:  
                a, symbole, b = parts
                a = float(a)
                b = float(b)
                result = calc.calcule(a, symbole, b)
            else:
                print("Format invalide !")
                continue

            print("Résultat :", result)

        except Exception as e:
            print("Erreur :", e)

if __name__ == "__main__":
    main()
