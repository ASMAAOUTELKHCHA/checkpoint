class Account:
     def __init__(self, account_number, account_holder, account_balance):
        self.account_number =str(account_number)
        self.account_holder =str(account_holder)
        self.account_balance =float(account_balance)

     def deposit(self, amount):
        self.account_balance += amount
        print(f"Dépôt de {amount} effectué. Nouveu solde : {self.account_balance}")

     def withdraw(self, amount):
        if self.account_balance >= amount:
            self.account_balance -= amount
            print(f"Retrait de {amount} effectué. Nouveu solde : {self.account_balance}")
        else:
            print("Fonds insuffisants pour effectuer ce retrait.")

     def check_balance(self):
        return self.account_balance

my_account = Account("123456", "ASMAA", 1000.0)
my_account.deposit(500.0)
my_account.withdraw(200.0)
print(f"Solde final : {my_account.check_balance()}")
